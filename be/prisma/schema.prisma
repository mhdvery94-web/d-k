generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// Users (Admin only)
model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique @db.VarChar(50)
  email        String   @unique @db.VarChar(100)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  name         String?  @db.VarChar(100)
  role         String   @default("admin") @db.VarChar(20)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("users")
}

// Categories
model Category {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(100)
  icon      String?  @db.VarChar(10)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  menus     Menu[]

  @@map("categories")
}

// Menus
model Menu {
  id              Int        @id @default(autoincrement())
  categoryId      Int        @map("category_id")
  name            String     @db.VarChar(200)
  description     String?    @db.Text
  price           Decimal    @db.Decimal(10, 2)
  discountPercent Int        @default(0) @map("discount_percent")
  stock           Int        @default(0)
  imageUrl        String?    @map("image_url") @db.VarChar(500)
  isActive        Boolean    @default(true) @map("is_active")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")
  category        Category   @relation(fields: [categoryId], references: [id])
  orderItems      OrderItem[]

  @@map("menus")
}

// Pending Payments (sebelum jadi order)
model PendingPayment {
  id                    Int       @id @default(autoincrement())
  sessionToken          String    @unique @map("session_token") @db.VarChar(100)
  customerName          String    @map("customer_name") @db.VarChar(100)
  customerPhone         String    @map("customer_phone") @db.VarChar(20)
  customerAddress       String    @map("customer_address") @db.Text
  customerPostalCode    String?   @map("customer_postal_code") @db.VarChar(10)
  customerKelurahan     String?   @map("customer_kelurahan") @db.VarChar(100)
  customerKecamatan     String?   @map("customer_kecamatan") @db.VarChar(100)
  customerKota          String?   @map("customer_kota") @db.VarChar(100)
  customerProvinsi      String?   @map("customer_provinsi") @db.VarChar(100)
  customerLatitude      Decimal?  @map("customer_latitude") @db.Decimal(10, 8)
  customerLongitude     Decimal?  @map("customer_longitude") @db.Decimal(11, 8)
  notes                 String?   @db.Text
  items                 Json
  subtotal              Decimal   @db.Decimal(10, 2)
  serviceFee            Decimal   @default(0) @map("service_fee") @db.Decimal(10, 2)
  deliveryFee           Decimal   @default(0) @map("delivery_fee") @db.Decimal(12, 2)
  discountPercent       Int       @default(0) @map("discount_percent")
  discountAmount        Decimal   @default(0) @map("discount_amount") @db.Decimal(12, 2)
  packingFee           Decimal   @default(0) @map("packing_fee") @db.Decimal(12, 2)
  shippingZoneCode     String?   @map("shipping_zone_code") @db.VarChar(10)
  shippingDistanceKm   Float?    @map("shipping_distance_km")
  total                 Decimal   @db.Decimal(12, 2)
  midtransTransactionId String?   @unique @map("midtrans_transaction_id") @db.VarChar(100)
  paymentUrl            String?   @map("payment_url") @db.Text
  qrCodeUrl             String?   @map("qr_code_url") @db.Text
  status                String    @default("pending") @db.VarChar(20)
  expiresAt             DateTime  @map("expires_at")
  createdAt             DateTime  @default(now()) @map("created_at")
  paidAt                DateTime? @map("paid_at")

  @@map("pending_payments")
}

// Orders
model Order {
  id                    Int        @id @default(autoincrement())
  orderNumber           String     @unique @map("order_number") @db.VarChar(50)
  pendingPaymentId      Int?       @unique @map("pending_payment_id")
  customerName          String     @map("customer_name") @db.VarChar(100)
  customerPhone         String     @map("customer_phone") @db.VarChar(20)
  customerAddress       String     @map("customer_address") @db.Text
  customerPostalCode    String?    @map("customer_postal_code") @db.VarChar(10)
  customerKelurahan     String?    @map("customer_kelurahan") @db.VarChar(100)
  customerKecamatan     String?    @map("customer_kecamatan") @db.VarChar(100)
  customerKota          String?    @map("customer_kota") @db.VarChar(100)
  customerProvinsi      String?    @map("customer_provinsi") @db.VarChar(100)
  customerLatitude      Decimal?   @map("customer_latitude") @db.Decimal(10, 8)
  customerLongitude     Decimal?   @map("customer_longitude") @db.Decimal(11, 8)
  notes                 String?    @db.Text
  subtotal              Decimal    @db.Decimal(10, 2)
  serviceFee            Decimal    @default(0) @map("service_fee") @db.Decimal(10, 2)
  deliveryFee           Decimal    @default(0) @map("delivery_fee") @db.Decimal(12, 2)
  discountPercent       Int        @default(0) @map("discount_percent")
  discountAmount        Decimal    @default(0) @map("discount_amount") @db.Decimal(12, 2)
  packingFee           Decimal    @default(0) @map("packing_fee") @db.Decimal(12, 2)
  shippingZoneCode     String?    @map("shipping_zone_code") @db.VarChar(10)
  shippingDistanceKm   Float?     @map("shipping_distance_km")
  total                 Decimal    @db.Decimal(12, 2)
  paymentStatus         String     @default("unpaid") @map("payment_status") @db.VarChar(20)
  orderStatus           String     @default("confirmed") @map("order_status") @db.VarChar(20)
  midtransTransactionId String?    @map("midtrans_transaction_id") @db.VarChar(100)
  paidAt                DateTime?  @map("paid_at")
  createdAt             DateTime   @default(now()) @map("created_at")
  updatedAt             DateTime   @updatedAt @map("updated_at")
  items                 OrderItem[]

  @@map("orders")
}

// Order Items
model OrderItem {
  id               Int      @id @default(autoincrement())
  orderId          Int      @map("order_id")
  menuId           Int      @map("menu_id")
  menuName         String   @map("menu_name") @db.VarChar(200)
  quantity         Int
  price            Decimal  @db.Decimal(10, 2)
  discountPercent  Int      @default(0) @map("discount_percent")
  subtotal         Decimal  @db.Decimal(10, 2)
  notes            String?  @db.Text
  order            Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menu             Menu     @relation(fields: [menuId], references: [id])

  @@map("order_items")
}

// Order Number Sequence (untuk generate unique order number)
model OrderSequence {
  id             Int     @id @default(autoincrement())
  datePrefix     String  @map("date_prefix") @db.VarChar(8)
  sequenceNumber Int     @default(0) @map("sequence_number")

  @@unique([datePrefix])
  @@map("order_sequences")
}

// OTP Tokens (persisten di database)
model OtpToken {
  id          Int      @id @default(autoincrement())
  email       String   @db.VarChar(100)
  hashedOtp   String   @map("hashed_otp") @db.VarChar(255)
  expiresAt   DateTime @map("expires_at")
  attempts    Int      @default(0)
  used        Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([email])
  @@index([expiresAt])
  @@map("otp_tokens")
}

// Checklist Items (pengecekan barang penjual)
model ChecklistItem {
  id         Int       @id @default(autoincrement())
  orderId    Int       @map("order_id")
  menuId     Int       @map("menu_id")
  menuName   String    @map("menu_name") @db.VarChar(200)
  quantity   Int
  checked    Boolean   @default(false)
  checkedAt  DateTime? @map("checked_at")
  checkedBy  String?   @map("checked_by") @db.VarChar(100)
  notes      String?   @db.Text
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@index([orderId])
  @@index([menuId])
  @@map("checklist_items")
}

// Shipping Zones (tarif ongkir berbasis jarak)
model ShippingZone {
  id        Int      @id @default(autoincrement())
  kodeZona  String   @unique @map("kode_zona") @db.VarChar(10)
  jarakMin  Float    @map("jarak_min")
  jarakMax  Float?   @map("jarak_max") // null = zona terakhir (tak terhingga)
  tarif     Int      @db.Int
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("shipping_zones")
}

// App Settings (key-value untuk packing_fee, wa_admin, store_address, dll)
model AppSetting {
  id        Int      @id @default(autoincrement())
  key       String   @unique @db.VarChar(50)
  value     String   @db.Text
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}